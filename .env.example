# Simulation is the default and is safe for local validation without Teams, audio routing, or an LLM.
PORT=4173
VOICE_BRIDGE_PROVIDER=simulation

# Local OpenAI-compatible model server, such as LM Studio. Qwen3 is the default profile.
# VOICE_BRIDGE_PROVIDER=openai-compatible
# LOCAL_MODEL_URL=http://127.0.0.1:1234/v1/
# VOICE_BRIDGE_LOCAL_MODEL=qwen3-8b

# Voice Clone Module's cached local Qwen bridge. The default model key is qwen3-8b.
# VOICE_BRIDGE_PROVIDER=local-qwen
# LOCAL_QWEN_URL=http://127.0.0.1:8001/
# VOICE_BRIDGE_LOCAL_MODEL=qwen3-8b

# Existing EVA ACP bridge backed by an authenticated GitHub Copilot CLI.
# VOICE_BRIDGE_PROVIDER=copilot-acp
# COPILOT_ACP_URL=http://127.0.0.1:8888/
# COPILOT_ACP_MODEL=claude-sonnet-4.6

# Client TTS routing. Leave VOICE_BRIDGE_TTS_MODE unset (or set it to auto) to
# choose remote when VOICE_BRIDGE_REMOTE_TTS_URL is present, otherwise localhost.
# LOCAL_VOICE_BRIDGE_URL=http://127.0.0.1:8090/
# VOICE_BRIDGE_TTS_MODE=remote
# VOICE_BRIDGE_REMOTE_TTS_URL=http://gpu-tts-host:8090/
# VOICE_BRIDGE_TTS_AUTH_TOKEN=replace-with-a-long-shared-secret

# GPU server TTS settings, used by tools/tts-server.sh on the synthesis machine.
# Use a separate .env on that machine with these values instead.
# VOICE_BRIDGE_TTS_HOST=0.0.0.0
# VOICE_BRIDGE_TTS_PORT=8090
# VOICE_BRIDGE_TTS_CACHE_DIR=/home/operator/.cache/atsla/greetings
# VOICE_CLONE_DEVICE=auto
# VOICE_BRIDGE_TTS_AUTH_TOKEN=replace-with-a-long-shared-secret

# Set VOICE_BRIDGE_TTS_MODE=local to force local synthesis explicitly.

# Linux PipeWire routing. Devices are only created when this is explicitly true, using POST /v1/audio/start
# or tools/audio-bridge.sh start. Select voice_bridge_conference as your call's speaker and
# voice_bridge_agent.monitor as its microphone. Set this only after testing the dry run.
# VOICE_BRIDGE_ENABLE_AUDIO_CONTROL=true
# VOICE_BRIDGE_AUDIO_OUTPUT=pipewire
# VOICE_BRIDGE_AGENT_SINK=voice_bridge_agent

# Whisper segmented live capture. Use tools/bootstrap-whisper.sh to build a local whisper.cpp binary.
# WHISPER_BIN=/absolute/path/to/whisper-cli
# WHISPER_MODEL=/absolute/path/to/ggml-base.en.bin
# VOICE_BRIDGE_SILENCE_DB=-45

# Knowledge roots. Client-specific and global roots must not overlap.
# VOICE_BRIDGE_CLIENTS_ROOT=/absolute/path/to/Voice Bridge Clients
# VOICE_BRIDGE_GLOBAL_KNOWLEDGE_PATH=/absolute/path/to/Voice Bridge Knowledge